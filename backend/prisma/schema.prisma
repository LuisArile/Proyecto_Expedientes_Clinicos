generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Rol {
  idRol    Int              @id @default(autoincrement())
  nombre   String           @unique @db.NVarChar(50)
  permisos PermisosPorRol[]
  usuarios Usuario[]

  @@map("Rol")
}

model Permiso {
  idPermiso Int              @id @default(autoincrement())
  nombre    String           @unique @db.NVarChar(50)
  roles     PermisosPorRol[]

  @@map("Permiso")
}

model PermisosPorRol {
  idRol     Int
  idPermiso Int
  permiso   Permiso @relation(fields: [idPermiso], references: [idPermiso])
  rol       Rol     @relation(fields: [idRol], references: [idRol])

  @@id([idRol, idPermiso])
  @@map("PermisosPorRol")
}

model Usuario {
  id                   Int                  @id @default(autoincrement())
  nombreUsuario        String               @unique
  correo               String               @unique
  clave                String
  activo               Boolean              @default(true)
  createdAt            DateTime             @default(now())
  apellido             String
  especialidad         String?
  nombre               String
  ultimoAcceso         DateTime?
  updatedAt            DateTime             @updatedAt
  idRol                Int
  debeCambiarPassword Boolean  @default(true)
  auditorias           Auditoria[]
  consultasMedicas     ConsultaMedica[]
  registrosPreclinicos registroPreclinico[]
  rol                  Rol                  @relation(fields: [idRol], references: [idRol])

  citasCreadas    Cita[]      @relation("citasCreadas")
  seguimientos    Seguimiento[]

  @@map("Usuario")
}

model Auditoria {
  id        Int      @id @default(autoincrement())
  usuarioId Int?
  accion    String
  detalles  String?
  fecha     DateTime @default(now())
  usuario   Usuario? @relation(fields: [usuarioId], references: [id])
}

model Paciente {
  idPaciente      Int         @id @default(autoincrement())
  dni             String      @db.NVarChar(20)
  nombre          String      @db.NVarChar(50)
  apellido        String      @db.NVarChar(50)
  correo          String?     @db.NVarChar(100)
  telefono        String?     @db.NVarChar(20)
  fechaNacimiento DateTime    @db.Date
  direccion       String?     @db.NVarChar(100)
  sexo            String?     @db.NVarChar(50)
  expedientes     Expediente?

  citas           Cita[]

  @@map("Paciente")
}

model Expediente {
  idExpediente         Int                  @id @default(autoincrement())
  idPaciente           Int                  @unique
  numeroExpediente     String               @unique @default(cuid()) @db.NVarChar(50)
  estado               Boolean              @default(true)
  fechaCreacion        DateTime             @default(now())
  fechaActualizacion   DateTime             @default(now()) @updatedAt
  observaciones        String?              @db.NVarChar(100)
  consultasMedicas     ConsultaMedica[]
  paciente             Paciente             @relation(fields: [idPaciente], references: [idPaciente])
  registrosPreclinicos registroPreclinico[]

  @@map("Expediente")
}

model registroPreclinico {
  id                 Int        @id @default(autoincrement())
  expedienteId       Int
  enfermeroId        Int
  presionArterial    String?
  temperatura        Float?
  peso               Float?
  frecuenciaCardiaca Int?
  observaciones      String?    @db.Text
  fechaRegistro      DateTime   @default(now())
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  talla              Int?
  enfermero          Usuario    @relation(fields: [enfermeroId], references: [id])
  expediente         Expediente @relation(fields: [expedienteId], references: [idExpediente])

  @@map("registroPreclinico")
}

model ConsultaMedica {
  id            Int            @id @default(autoincrement())
  expedienteId  Int
  medicoId      Int
  fechaConsulta DateTime       @default(now())
  motivo        String         @db.Text
  diagnostico   String         @db.Text
  observaciones String?        @db.Text
  tipoConsulta  String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  expediente    Expediente     @relation(fields: [expedienteId], references: [idExpediente])
  medico        Usuario        @relation(fields: [medicoId], references: [id])
  recetas       RecetaMedica[]
  examenes      ConsultaExamen[]

  @@map("ConsultaMedica")
}

model RecetaMedica {
  id             Int            @id @default(autoincrement())
  consultaId     Int
  medicamentoId  Int
  dosis          String
  duracion       String
  indicaciones   String?        @db.Text
  createdAt      DateTime       @default(now())

  consulta       ConsultaMedica @relation(fields: [consultaId], references: [id])
  medicamento    Medicamento    @relation(fields: [medicamentoId], references: [id])

  @@map("RecetaMedica")
}

model Examen {
  id              Int               @id @default(autoincrement())
  nombre          String            @db.NVarChar(100)
  especialidad    String            @db.NVarChar(100)
  estado          Boolean           @default(true)
  fechaCreacion   DateTime          @default(now())

  consultas       ConsultaExamen[]

  @@map("Examen")
}

model ConsultaExamen {
  id            Int             @id @default(autoincrement())
  consultaId    Int
  examenId      Int

  consulta      ConsultaMedica  @relation(fields: [consultaId], references: [id])
  examen        Examen          @relation(fields: [examenId], references: [id])

  createdAt     DateTime        @default(now())
  prioridad     String          @default("MEDIA")

  @@unique([consultaId, examenId]) 
  @@map("ConsultaExamen")
}

model Medicamento {
  id              Int              @id @default(autoincrement())
  nombre          String
  categoria       String
  estado          Boolean          @default(true)
  fechaCreacion   DateTime         @default(now())

  recetas         RecetaMedica[]

  @@map("Medicamento")
}

model Cita {
  idCita        Int      @id @default(autoincrement())
  pacienteId    Int
  fechaCita     DateTime
  horaCita      String   @db.NVarChar(20)
  motivo        String   @db.NVarChar(255)
  prioridad     String   @default("NORMAL") @db.NVarChar(20)  // NORMAL, URGENTE, EMERGENCIA
  tipo          String   @default("PROGRAMADA") @db.NVarChar(20) // PROGRAMADA, REGISTRO_DIA
  estado        String   @default("PROGRAMADO") @db.NVarChar(30)
  recepcionistaId Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  paciente      Paciente @relation(fields: [pacienteId], references: [idPaciente])
  recepcionista Usuario  @relation("citasCreadas", fields: [recepcionistaId], references: [id])
  seguimiento   Seguimiento[]

  @@map("Cita")
}

model Seguimiento {
  idSeguimiento Int      @id @default(autoincrement())
  citaId         Int
  estadoAnterior String   @db.NVarChar(30)
  estadoNuevo    String   @db.NVarChar(30)
  usuarioId      Int
  accion         String   @db.NVarChar(100)
  observaciones  String?  @db.NVarChar(255)
  fecha          DateTime @default(now())

  cita    Cita    @relation(fields: [citaId], references: [idCita], onUpdate: NoAction, onDelete: NoAction)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@map("Seguimiento")
}