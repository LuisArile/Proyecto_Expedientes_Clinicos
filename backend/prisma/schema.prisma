generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nombreUsuario String @unique
  correo     String   @unique
  clave      String
  rol       String
  activo    Boolean
  createdAt DateTime @default(now())

  auditorias Auditoria[]
}

model Auditoria {
  id          Int   @id @default(autoincrement())
  usuarioId   Int 
  accion      String
  fecha       DateTime @default(now())

  usuario     Usuario  @relation(fields: [usuarioId], references: [id])

}

model Paciente {
  idPaciente      Int          @id @default(autoincrement())
  dni             String       @db.NVarChar(20)
  nombre          String       @db.NVarChar(50)
  apellido        String       @db.NVarChar(50)
  correo          String?      @db.NVarChar(100)
  telefono        String?      @db.NVarChar(20)
  fechaNacimiento DateTime     @db.Date
  genero          String       @db.NVarChar(50)
  idResidencia    Int

  expedientes     Expediente[] 

  @@map("Paciente") 

} 

model Expediente {
  idExpediente       Int      @id @default(autoincrement())
  idPaciente         Int      @unique
  numeroExpediente   String   @unique @db.NVarChar(50)
  estado             Int      @db.TinyInt
  fechaCreacion      DateTime @default(now()) @db.Date
  fechaActualizacion DateTime @default(now()) @updatedAt
  observaciones      String?  @db.NVarChar(100)

  paciente           Paciente @relation(fields: [idPaciente], references: [idPaciente])

  @@map("Expediente")

} 