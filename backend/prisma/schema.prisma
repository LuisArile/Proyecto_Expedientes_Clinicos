generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "sqlserver"
    url      = env("DATABASE_URL")
}

model Usuario {
    id             Int      @id @default(autoincrement())
    nombre         String
    apellido       String
    email          String   @unique
    username       String   @unique
    password       String
    rol            String   // ADMINISTRADOR, DOCTOR, PACIENTE, RECEPCIONISTA
    activo         Boolean  @default(true)
    
    // Campos específicos
    especialidad   String?
    prevision      String?
    turno          String?
    
    ultimoAcceso   DateTime?
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt

    auditorias     Auditoria[]
}

model Auditoria {
    id             Int      @id @default(autoincrement())
    usuarioId      Int?
    usuario        Usuario? @relation(fields: [usuarioId], references: [id])
    
    accion         String
    detalles       String?
    ip             String?
    userAgent      String?
    
    fecha          DateTime @default(now())
}
